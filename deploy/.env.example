# 복사 → `.env` 로 채우기.  ★ .env 는 .gitignore (절대 커밋 금지) ★
# docker compose -f docker-compose.example.yml 가 이 값들을 ${VAR}로 주입합니다.

RUSTDESK_IMAGE=rustdesk/rustdesk-server:latest   # 또는 본인 레지스트리 이미지
RUSTDESK_DOMAIN=remote.example.com               # 서버 도메인 (scheme 없이)
RUSTDESK_KEY=                                     # 서버 공개키 (id_ed25519.pub 내용)
AAD_TENANT=                                       # Entra 테넌트 GUID
AAD_CLIENT=                                       # Entra 앱(클라이언트) ID
ALLOWED_DOMAIN=                                   # (선택) 예: example.com
AUTHCONFIG_IMAGE=                                 # (선택) 게이트를 prebuilt 이미지로 쓸 때
COMPOSE_NETWORK=rustdesk-net
