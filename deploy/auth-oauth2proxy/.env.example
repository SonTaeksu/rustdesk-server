# 복사 → .env 로 채우기. ★.env 는 커밋 금지(시크릿 포함)★
AAD_TENANT=<tenant-guid>
AAD_CLIENT=<app-client-id>
AAD_CLIENT_SECRET=<client-secret>          # confidential 앱 시크릿 (device-code 공개 클라와 별개)
COOKIE_SECRET=<openssl rand -base64 32>    # 정확히 16/24/32 바이트
ALLOWED_DOMAIN=yourcompany.com             # 이 도메인 계정만 허용 (전체 허용은 *)
STAFF_HOST=staff.example.com               # 상담원 페이지 호스트(서브도메인 권장)
